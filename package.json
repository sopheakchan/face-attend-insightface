{
  "name": "faceattend-root",
  "version": "1.0.0",
  "description": "Face recognition attendance system - root runner",
  "scripts": {
    "start": "npm run dev",
    "predev": "npm install --prefix frontend",
    "dev": "concurrently --names \"API,FRONTEND\" --prefix-colors \"cyan,green\" \"python recognition_api.py\" \"npm run dev --prefix frontend\"",
    "install:frontend": "npm install --prefix frontend",
    "setup": "pip install -r requirements.txt && npm run install:frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
